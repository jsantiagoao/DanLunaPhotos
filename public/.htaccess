Options -MultiViews
RewriteEngine On

# Redirigir rutas con hash legacy (/#/ruta → /ruta)
RewriteCond %{QUERY_STRING} ^$
RewriteRule ^#/(.*)$ /$1 [R=301,L]

# Servir index.html para todas las rutas que no sean archivos/carpetas reales
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^ /index.html [L]
