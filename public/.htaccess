Options -MultiViews
RewriteEngine On

# Redirigir rutas con hash legacy (/#/ruta → /ruta)
RewriteCond %{QUERY_STRING} ^$
RewriteRule ^#/(.*)$ /$1 [R=301,L]

# Servir archivos y carpetas reales directamente (assets, js, css, imágenes)
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Todo lo demás → index.php (meta injection + Angular SPA)
DirectoryIndex index.php index.html
RewriteRule ^ /index.php [L]
